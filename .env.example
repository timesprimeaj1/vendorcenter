# Core
NODE_ENV=development
APP_NAME=VendorCenter
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000

# CORS — comma-separated origins allowed to call the API
# Local: * (allow all)
# Production: https://your-frontend-domain.vercel.app,https://vendorcenter.in
CORS_ORIGINS=*

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendorcenter
DB_USER=postgres
DB_PASSWORD=258025

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Object storage (local/dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_BUCKET=vendorcenter-media

# Auth
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_FROM_EMAIL=otp@vendorcenter.in

# SMTP (Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TRANSPORT_MODE=mock
EMAIL_FROM_NOREPLY=noreply@vendorcenter.in
EMAIL_FROM_OTP=otp@vendorcenter.in
EMAIL_FROM_PAYMENTS=payments@vendorcenter.in
EMAIL_FROM_BOOKINGS=bookings@vendorcenter.in
EMAIL_FROM_SUPPORT=support@vendorcenter.in
EMAIL_FROM_VENDORS=vendors@vendorcenter.in
EMAIL_FROM_ADMIN=admin@vendorcenter.in

# Maps
MAP_PROVIDER=openstreetmap
